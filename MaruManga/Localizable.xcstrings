{
  "sourceLanguage" : "en",
  "strings" : {
    "%@ - Page %lld" : {
      "comment" : "A string that appears in the top-left corner of the reader when a manga is being read. The first argument is the manga title, or \"Manga\" if the title is unknown. The second argument is the page number.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ - Page %2$lld"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ - %2$lldページ"
          }
        }
      }
    },
    "%lld / %lld Read" : {
      "comment" : "A string showing the current reading progress of a book. The first argument is the current page number. The second argument is the total number of pages in the book.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld / %2$lld Read"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld / %2$lld 読了"
